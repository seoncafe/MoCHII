&parameters
 ! Dusty photoionized sphere: dust competes with the gas for ionizing
 ! photons.  In the ionizing band the grains both absorb and forward-scatter
 ! (WD01/D03 Milky Way mixture); the absorbed energy heats the grains to an
 ! equilibrium temperature, which is re-emitted in the infrared.  A uniform
 ! sphere is built from the namelist on a 'car' Cartesian grid.
 ! Setting par%ion_add_dust yields an equilibrium T_dust and the infrared
 ! output <name>_dustir.txt.
 par%no_photons    = 2.0e6
 par%iseed         = 1234

 par%grid_type     = 'car'
 par%nx = 48
 par%ny = 48
 par%nz = 48
 par%xmax = 4.0
 par%ymax = 4.0
 par%zmax = 4.0
 par%nH_const      = 100.0          ! cm^-3 inside the sphere
 par%rmax          = 3.8            ! sphere radius (pc); nH = 0 outside
 par%distance_unit = 'pc'

 par%use_ion_band  = .true.
 par%nnu_ion       = 32
 par%tstar         = 4.0e4          ! blackbody source [K]
 par%luminosity    = 3.177837e38    ! ionizing-band luminosity [erg/s]
 par%He_abund      = 0.1
 par%xHI_init      = 1.0e-3

 par%gas_niter     = 40
 par%conv_crit     = 'vol'
 par%gas_tol       = 5.0e-3
 par%case_ab       = 'B'
 par%te_fixed      = 1.0e4          ! fixed electron temperature [K]

 par%dust_model      = 'global_dgr'
 par%ion_add_dust    = .true.       ! EUV dust absorption + grain heating
 par%ion_dust_scatter = .true.      ! forward scattering in the ionizing band
 par%ion_dust_kext   = '../../data/kext_albedo_WD_MW_3.1_60_D03.all_2009'
 par%cext_dust       = 4.868e-22    ! Milky Way C_ext(V) per H [cm^2]
 par%DGR             = 1.0

 par%source_geometry = 'point'
 par%file_format     = 'hdf5'
 par%out_file        = 'dusty_nebula.h5'
/
