&parameters
 ! H II region: a photoionized gas shell around a hot star with metal
 ! cooling and a self-consistent electron temperature.  Heavy-element ions
 ! (C, N, O, Ne, S) are tracked one stage at a time; the thermal balance is
 ! solved from the same radiation field, and emission lines are computed by
 ! the n-level solver.  A uniform-density shell (central cavity + gas) is
 ! built directly from the namelist on a 'car' Cartesian grid (no grid file).
 ! Outputs: <name>_rates (rates + state), <name>_lines.txt (emission lines),
 ! and <name>_nebcont.txt (nebular continuum).
 par%no_photons    = 2.0e6
 par%iseed         = 1234

 par%grid_type     = 'car'
 par%nx = 48
 par%ny = 48
 par%nz = 48
 par%xmax = 3.5
 par%ymax = 3.5
 par%zmax = 3.5
 par%nH_const      = 100.0          ! cm^-3 inside the shell
 par%rmin          = 0.97           ! inner cavity radius (pc); nH = 0 inside
 par%rmax          = 3.08           ! outer shell radius (pc); nH = 0 outside
 par%distance_unit = 'pc'
 par%dust_model    = 'none'         ! gas-only

 par%use_ion_band  = .true.
 par%nnu_ion       = 32
 par%tstar         = 4.0e4          ! blackbody source [K]
 par%luminosity    = 1.353758e39    ! ionizing-band luminosity [erg/s]
 par%He_abund      = 0.1
 par%xHI_init      = 1.0e-3

 par%gas_niter     = 40
 par%conv_crit     = 'vol'          ! volume-integrated convergence
 par%gas_tol       = 1.0e-2
 par%gas_tol_te    = 2.0e-2
 par%case_ab       = 'B'

 par%solve_te      = .true.         ! self-consistent electron temperature
 par%te_min        = 3.0e3
 par%te_max        = 3.0e4
 par%use_metals    = .true.
 par%atomic_dir    = '../../data/atomic'
 par%abund_C       = 2.2e-4
 par%abund_N       = 4.0e-5
 par%abund_O       = 3.3e-4
 par%abund_Ne      = 5.0e-5
 par%abund_S       = 9.0e-6

 par%source_geometry = 'point'
 par%file_format     = 'hdf5'
 par%out_file        = 'hii_region.h5'
/
