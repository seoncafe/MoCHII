&parameters
 ! Photoionization by a realistic young stellar population instead of a
 ! blackbody.  par%ion_spectrum reads a 2-column (E[eV], L_E) SED file; here
 ! the FSPS 10 Myr population (make_spectrum.py converts the MoCafe SED
 ! spec_young_fsps.dat).  A 10 Myr population is SOFT -- its hot O stars have
 ! died, so it makes far fewer He-ionizing photons than the 40 kK blackbody
 ! of the other examples.
 par%no_photons    = 1.0e6
 par%iseed         = 1234

 par%grid_type     = 'car'
 par%nx = 48
 par%ny = 48
 par%nz = 48
 par%xmax = 4.0
 par%ymax = 4.0
 par%zmax = 4.0
 par%nH_const      = 100.0
 par%rmax          = 3.8
 par%distance_unit = 'pc'
 par%dust_model    = 'none'

 par%use_ion_band  = .true.
 par%nnu_ion       = 32
 par%ion_spectrum  = 'fsps_young_eV.dat'   ! stellar SED (E[eV], L_E), not a blackbody
 par%luminosity    = 3.177837e38           ! ionizing-band luminosity [erg/s]
 par%He_abund      = 0.1
 par%xHI_init      = 1.0e-3

 par%gas_niter     = 40
 par%conv_crit     = 'vol'
 par%gas_tol       = 5.0e-3
 par%case_ab       = 'B'
 par%te_fixed      = 1.0e4

 par%source_geometry = 'point'
 par%out_file        = 'stellar_spectrum.h5'
/
