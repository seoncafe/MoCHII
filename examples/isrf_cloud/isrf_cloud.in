&parameters
 ! A neutral cloud bathed in the standard interstellar radiation field, given
 ! by an ISRF PRESET.  par%ext_spectrum = 'draine' is the Draine (1978) FUV
 ! field (reserved names 'draine'/'habing'/'mathis'; FUV-only, 5-13.6 eV,
 ! ABSOLUTE).  A preset REQUIRES par%add_fuv and fills the FUV bins only -- the
 ! ionizing bins carry exactly zero, so no H-ionizing photons enter and the
 ! bulk of the cloud stays neutral.  par%ext_scale multiplies the preset
 ! ('mathis' / 'habing' are drop-in alternatives; setting par%ext_intensity
 ! would instead rescale the preset to a target band J).
 !
 ! What this demonstrates: the FUV field penetrates the cloud (attenuated only
 ! by dust here) and photoionizes the low-threshold metals -- carbon (11.26 eV)
 ! and magnesium (7.65 eV) -- in an outer skin, making the C II zone that the
 ! ionizing band alone cannot make.  Toward the center the field is dust-
 ! attenuated, so C recombines to C I: a real penetration gradient.  Dust
 ! extinction (par%ion_add_dust, the D03 MW table) is what stops the FUV in
 ! the cloud; without it the field would ionize C throughout.
 !
 ! Temperatures are NOT the point here (par%te_fixed = 100 K, no thermal
 ! solve): this run isolates the FUV penetration and the metal-ionization
 ! skin.  The pdr example adds grain photoelectric heating and metal-line
 ! cooling for a self-consistent PDR temperature.
 !
 ! Tuning: the C I photoionization rate under the Draine field is ~1e2-1e3
 ! times the C recombination rate at these densities, so C stays fully ionized
 ! until the FUV is dust-attenuated by ~1-2 dex.  Two knobs matter.  (1) DENSITY
 ! sets the optical depth: a thin diffuse cloud (nH = 100, 0.45 pc) reaches only
 ! tau_FUV ~ 0.1 -- C II = 1 everywhere, no gradient; a dense clump nH = 5e3
 ! gives tau_FUV ~ 5 across the radius, so C II fills the outer skin (C II ~ 0.8
 ! at the edge) and drops to pure C I toward the center over ~4 cells -- a real
 ! penetration gradient.  (2) ELECTRONS: par%metal_ne must be on so the metal
 ! cascade feeds n_e; with n_e = 0 (H neutral, no H electrons) NOTHING
 ! recombines and C stays II regardless of attenuation.  Raising nH sharpens
 ! the skin against the edge; lowering it thins the cloud toward C II
 ! everywhere; raising par%ext_scale drives the skin deeper.
 par%no_photons    = 4.0e6
 par%iseed         = 1234

 par%grid_type     = 'car'
 par%nx = 48
 par%ny = 48
 par%nz = 48
 par%xmax = 0.5
 par%ymax = 0.5
 par%zmax = 0.5
 par%nH_const      = 5.0e3          ! cm^-3 inside the cloud (dense clump; see tuning)
 par%rmax          = 0.45           ! cloud radius (pc); nH = 0 outside
 par%distance_unit = 'pc'
 par%dust_model    = 'global_dgr'

 par%use_ion_band  = .true.
 par%nnu_ion       = 16             ! ionizing bins; they stay empty (FUV-only field)
 par%add_fuv       = .true.         ! required by an ISRF preset
 par%efuv_min      = 6.0            ! lower FUV edge [eV]
 par%nnu_fuv       = 16
 par%He_abund      = 0.1
 par%xHI_init      = 1.0            ! start neutral

 !--- external ISRF preset only (no internal star)
 par%nsource       = 0
 par%ext_spectrum  = 'draine'       ! Draine 1978 FUV field; 'mathis'/'habing' also valid
 par%ext_scale     = 1.0            ! multiplier on the preset

 !--- metals: default C/N/O/Ne/S abundances plus gas-phase Mg (FUV-ionizable)
 par%use_metals    = .true.
 par%atomic_dir    = '../../data/atomic'
 par%abund_Mg      = 3.0e-6
 par%ion_metal_abs = .true.         ! metal photoionization opacity in the band
 par%metal_ne      = .true.         ! metal electrons in n_e: REQUIRED here so C II
                                    ! can recombine (H is neutral -> no H electrons;
                                    ! with n_e = 0 nothing recombines and C stays II)

 !--- dust extinction stops the FUV inside the cloud
 par%ion_add_dust  = .true.
 par%ion_dust_kext = '../../data/kext_albedo_WD_MW_3.1_60_D03.all_2009'
 par%cext_dust     = 4.868e-22
 par%DGR           = 1.0

 par%gas_niter     = 15
 par%conv_crit     = 'cell'         ! cell-max, NOT 'vol': H stays neutral so the
                                    ! ionized volume ~ 0 and the volume-integrated
                                    ! metric (normalized by it) is meaningless here
 par%gas_tol       = 5.0e-3
 par%case_ab       = 'B'
 par%te_fixed      = 100.0          ! fixed T [K]; temperatures are not the point here

 par%file_format   = 'hdf5'
 par%out_file      = 'isrf_cloud.h5'
/
