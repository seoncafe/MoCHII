&parameters
 ! Classic Stromgren sphere: H + He photoionization equilibrium around a
 ! central hot star.  Uniform-density sphere built directly from the namelist
 ! (no grid file): a 'car' Cartesian grid with nH set inside radius rmax.
 par%no_photons    = 1.0e6
 par%iseed         = 1234

 par%grid_type     = 'car'
 par%nx = 48
 par%ny = 48
 par%nz = 48
 par%xmax = 4.0
 par%ymax = 4.0
 par%zmax = 4.0
 par%nH_const      = 100.0          ! cm^-3 inside the sphere
 par%rmax          = 3.8            ! sphere radius (pc); nH = 0 outside
 par%distance_unit = 'pc'
 par%dust_model    = 'none'

 par%use_ion_band  = .true.
 par%nnu_ion       = 32
 par%tstar         = 4.0e4          ! blackbody source [K]
 par%luminosity    = 3.177837e38    ! ionizing-band luminosity [erg/s]
 par%He_abund      = 0.1
 par%xHI_init      = 1.0e-3

 par%gas_niter     = 40
 par%conv_crit     = 'vol'
 par%gas_tol       = 5.0e-3
 par%case_ab       = 'B'
 par%te_fixed      = 1.0e4          ! fixed electron temperature [K]

 par%source_geometry = 'point'
 par%out_file        = 'stromgren_sphere.h5'
/
