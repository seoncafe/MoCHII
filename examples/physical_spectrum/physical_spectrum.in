&parameters
 ! Stromgren sphere whose stellar spectrum is given in PHYSICAL units.  The
 ! source is a 4e4 K blackbody tabulated as L_lambda [erg/s/A] vs lambda [A]
 ! (make_physical_spectrum.py writes star_llam.txt), read with
 ! par%spectrum_type = 'per_ang'.  A physical (absolute) spectrum CARRIES its
 ! own luminosity: par%luminosity is left UNSET, so the ionizing-band
 ! luminosity is DERIVED from the file's ionizing-segment integral and printed
 ! in the log (' ION: derived ionizing luminosity [erg/s] = ...').  Setting
 ! par%luminosity would instead RESCALE the file to that value (a note is
 ! logged) and the file would act only as a shape.
 !
 ! The file is normalized so its derived luminosity is the stromgren_sphere
 ! example value 3.177837e38 erg/s, so this run reproduces that example's
 ! ionization structure -- same physics, luminosity moved from the namelist
 ! into the spectrum file.  With a physical-type file par%tstar is not used.
 par%no_photons    = 1.0e6
 par%iseed         = 1234

 par%grid_type     = 'car'
 par%nx = 48
 par%ny = 48
 par%nz = 48
 par%xmax = 4.0
 par%ymax = 4.0
 par%zmax = 4.0
 par%nH_const      = 100.0          ! cm^-3 inside the sphere
 par%rmax          = 3.8            ! sphere radius (pc); nH = 0 outside
 par%distance_unit = 'pc'
 par%dust_model    = 'none'

 par%use_ion_band  = .true.
 par%nnu_ion       = 32
 par%ion_spectrum  = 'star_llam.txt'   ! stellar SED, physical units (see below)
 par%spectrum_type = 'per_ang'         ! col1 lambda [A], col2 L_lambda [erg/s/A]
 !--- par%luminosity intentionally UNSET: the ionizing luminosity is derived
 !--- from the file.  Uncommenting the next line would rescale the file to it:
 !  par%luminosity = 3.177837e38
 par%He_abund      = 0.1
 par%xHI_init      = 1.0e-3

 par%gas_niter     = 40
 par%conv_crit     = 'vol'
 par%gas_tol       = 5.0e-3
 par%case_ab       = 'B'
 par%te_fixed      = 1.0e4          ! fixed electron temperature [K]

 par%source_geometry = 'point'
 par%out_file        = 'physical_spectrum.h5'
/
