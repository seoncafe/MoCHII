 par%solve_te      = .true.
 par%te_min        = 3.0e3
 par%te_max        = 3.0e4
 par%gas_tol_te    = 5.0e-3
 par%atomic_dir    = '../../data/atomic'
 par%use_metals    = .true.
 par%abund_C       = 2.2e-4
 par%abund_N       = 4.0e-5
 par%abund_O       = 3.3e-4
 par%abund_Ne      = 5.0e-5
 par%abund_S       = 9.0e-6
