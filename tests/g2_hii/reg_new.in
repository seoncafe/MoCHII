 par%luminosity    = 2.587394e38
 par%xHI_init      = 1.0e-3
 par%xHeI_init     = 0.5
 par%xHeII_init    = 0.5
 par%He_abund      = 0.1
 par%ion_add_dust  = .false.
 par%gas_niter     = 3
 par%gas_tol       = 5.0e-3
 par%ion_relax     = 1.0
