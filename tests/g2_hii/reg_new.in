 par%abund_Mg      = 3.0e-6
 par%abund_Fe      = 3.0e-7
 par%use_sec_ion   = .false.
 par%metal_freefree = .false.
 par%source_geometry = 'point'
 par%file_format     = 'hdf5'
 par%out_file        = 'reg_new.h5'
