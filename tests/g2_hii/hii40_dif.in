&parameters
 ! MoCHII G2 gate: MOCASSIN/Lexington HII20 benchmark.
 ! Blackbody 20 kK, Q_H = 4.26e49 s^-1, nH = 100 cm^-3, hollow shell
 ! Rin = 3e18 cm, Rout = 9.5e18 cm; abundances He 0.1, C 2.2e-4, N 4e-5,
 ! O 3.3e-4, Ne 5e-5, S 9e-6.  Reference: MOCASSIN baseline
 ! Te(H+) = 7046.6 K (tests/baselines/01_gas_HII20).

 par%no_photons    = 4.0e7
 par%no_print      = 4.0e7
 par%iseed         = 1234

 par%grid_type     = 'amr'
 par%amr_file      = 'hii40_L6.fits'
 par%dust_model    = 'none'
 par%distance_unit = 'pc'

 !--- ionizing band: L set so that Q_H = 4.26e49 (mean E = 19.834 eV)
 par%use_ion_band  = .true.
 par%nnu_ion       = 32
 par%eion_min      = 13.598
 par%eion_max      = 100.0
 par%tstar         = 4.0e4
 par%luminosity    = 1.353758e39

 !--- ionized start (fast convergence; equilibrium is unique)
 par%xHI_init      = 1.0e-3
 par%xHeI_init     = 0.5
 par%xHeII_init    = 0.5
 par%He_abund      = 0.1
 par%ion_add_dust  = .false.

 !--- G1/G2 iteration: thermal balance + metals, case B
 par%gas_niter     = 100
 par%gas_tol       = 5.0e-3
 par%ion_relax     = 1.0
 par%case_ab       = 'A'
 par%solve_te      = .true.
 par%diffuse_field = .true.
 par%te_min        = 3.0e3
 par%te_max        = 3.0e4
 par%gas_tol_te    = 5.0e-3
 par%atomic_dir    = '../../data/atomic'
 par%use_metals    = .true.
 par%abund_C       = 2.2e-4
 par%abund_N       = 4.0e-5
 par%abund_O       = 3.3e-4
 par%abund_Ne      = 5.0e-5
 par%abund_S       = 9.0e-6

 par%source_geometry = 'point'
 par%file_format     = 'hdf5'
 par%out_file        = 'hii40_dif.h5'
/
