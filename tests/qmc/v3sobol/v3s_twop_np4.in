&parameters
 ! G-two-points: two internal point sources.  Optically thin box -> the
 ! band-integrated J(r) must equal the analytic superposition
 !   J(r) = sum_i L_i / (16 pi^2 |r - r_i|^2).
 ! src 1 at (-1, 0, 0) pc with L = 3e37; src 2 at (+1, +0.5, 0) pc with L = 1e37.

 par%no_photons    = 2.0e7
 par%no_print      = 2.0e7
 par%iseed         = 1234

 par%grid_type     = 'car'
 par%car_walk      = 'dda'
 par%nx            = 32
 par%ny            = 32
 par%nz            = 32
 par%xmax          = 2.0
 par%ymax          = 2.0
 par%zmax          = 2.0
 par%nH_const      = 1.0e-4
 par%dust_model    = 'none'
 par%distance_unit = 'pc'

 par%use_ion_band  = .true.
 par%nnu_ion       = 32
 par%eion_min      = 13.598
 par%eion_max      = 100.0
 par%tstar         = 4.0e4

 par%xHI_init      = 1.0
 par%He_abund      = 0.0
 par%ion_add_dust  = .false.

 par%gas_niter     = 0

 par%nsource       = 2
 par%src_x(1)      = -1.0
 par%src_y(1)      =  0.0
 par%src_z(1)      =  0.0
 par%src_lum(1)    =  3.0e37
 par%src_x(2)      =  1.0
 par%src_y(2)      =  0.5
 par%src_z(2)      =  0.0
 par%src_lum(2)    =  1.0e37

 par%file_format   = 'hdf5'
 par%out_file      = 'v3s_twop_np4.h5'
 par%launch_sequence = 'sobol'
 par%qmc_seed        = 101
/
