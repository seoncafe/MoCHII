 par%ny            = 32
 par%nz            = 32
 par%xmax          = 2.0
 par%ymax          = 2.0
 par%zmax          = 2.0
 par%nH_const      = 200.0
 par%rmax          = 1.9
 par%dust_model    = 'none'
 par%distance_unit = 'pc'
 par%use_ion_band  = .true.
 par%nnu_ion       = 16
 par%eion_min      = 13.598
 par%eion_max      = 100.0
 par%tstar         = 4.0e4
 par%luminosity    = 1.5e37
 par%xHI_init      = 1.0
 par%xHeI_init     = 1.0
 par%xHeII_init    = 0.0
 par%He_abund      = 0.1
