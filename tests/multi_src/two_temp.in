&parameters
 ! G-spectra: two internal point sources of EQUAL ionizing luminosity but
 ! different spectra (Planck tstar = 3e4 and 5e4 K).  The volume-summed
 ! band spectrum J_nu(bin) must equal the sum of the two single-source runs
 ! (two_temp_s1 + two_temp_s2) to MC noise.

 par%no_photons    = 2.0e7
 par%no_print      = 2.0e7
 par%iseed         = 1234

 par%grid_type     = 'car'
 par%car_walk      = 'dda'
 par%nx            = 32
 par%ny            = 32
 par%nz            = 32
 par%xmax          = 2.0
 par%ymax          = 2.0
 par%zmax          = 2.0
 par%nH_const      = 1.0e-4
 par%dust_model    = 'none'
 par%distance_unit = 'pc'

 par%use_ion_band  = .true.
 par%nnu_ion       = 32
 par%eion_min      = 13.598
 par%eion_max      = 100.0
 par%tstar         = 4.0e4

 par%xHI_init      = 1.0
 par%He_abund      = 0.0
 par%ion_add_dust  = .false.

 par%gas_niter     = 0

 par%nsource       = 2
 par%src_x(1)      = -0.5
 par%src_tstar(1)  =  3.0e4
 par%src_lum(1)    =  1.0e37
 par%src_x(2)      =  0.5
 par%src_tstar(2)  =  5.0e4
 par%src_lum(2)    =  1.0e37

 par%file_format   = 'hdf5'
 par%out_file      = 'twotemp.h5'
/
