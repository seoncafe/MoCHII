&parameters
 ! G-ext-je (rescale): the SAME absolute J_E file (band int 1e-5) but ALSO set
 ! ext_intensity = 2e-5, which rescales the field so the band-integrated J = 2e-5
 ! -> the interior <J> doubles vs st_extje.in.

 par%no_photons    = 2.0e7
 par%no_print      = 2.0e7
 par%iseed         = 1234

 par%grid_type     = 'car'
 par%car_walk      = 'dda'
 par%nx            = 32
 par%ny            = 32
 par%nz            = 32
 par%xmax          = 2.0
 par%ymax          = 2.0
 par%zmax          = 2.0
 par%nH_const      = 1.0e-4
 par%dust_model    = 'none'
 par%distance_unit = 'pc'

 par%use_ion_band  = .true.
 par%nnu_ion       = 32
 par%eion_min      = 13.598
 par%eion_max      = 100.0

 par%xHI_init      = 1.0
 par%He_abund      = 0.0
 par%ion_add_dust  = .false.

 par%gas_niter     = 0

 par%nsource       = 0
 par%spectrum_type = 'le'
 par%ext_spectrum  = 'extje.txt'
 par%ext_geometry  = 'rec'
 par%ext_intensity = 2.0e-5

 par%file_format   = 'hdf5'
 par%out_file      = 'st_extje2.h5'
/
