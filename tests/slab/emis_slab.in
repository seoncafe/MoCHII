&parameters
 ! Check: does the xy-periodic SLAB produce line/emissivity output?
 ! Full physics: thermal + metals + emis_output.  Beam from top, nH=100.
 par%no_photons=4.0e6
 par%no_print=4.0e6
 par%iseed=1234
 par%grid_type='car'
 par%car_walk='dda'
 par%nx=1
 par%ny=1
 par%nz=48
 par%xmax=0.03125
 par%ymax=0.03125
 par%zmax=1.5
 par%nH_const=100.0
 par%rmax=100.0
 par%dust_model='none'
 par%distance_unit='pc'
 par%xy_periodic=.true.
 par%use_ion_band=.true.
 par%nnu_ion=32
 par%eion_min=13.598
 par%eion_max=100.0
 par%tstar=4.0e4
 par%He_abund=0.1
 par%xHI_init=1.0
 par%gas_niter=40
 par%gas_tol=3.0e-3
 par%conv_crit='vol'
 par%solve_te=.true.
 par%te_min=3.0e3
 par%te_max=3.0e4
 par%use_metals=.true.
 par%atomic_dir='../../data/atomic'
 par%abund_C=2.2e-4
 par%abund_N=4.0e-5
 par%abund_O=3.3e-4
 par%abund_Ne=5.0e-5
 par%abund_S=9.0e-6
 par%emis_output=.true.
 par%source_geometry='slab'
 par%slab_faces='top'
 par%slab_top_mode='beam'
 par%slab_top_theta=0.0
 par%slab_top_source=3.0
 par%file_format='hdf5'
 par%out_file='emis_slab.h5'
/
