&parameters
 ! PP6 gate G-e: plane-parallel photoionization slab.  Beam from top, full
 ! ionization solve (case B, OTS).  Front at d = Phi/(nH^2 alpha_B), the
 ! plane-parallel Stromgren depth.  nx=ny=1 column; cubic dcx=2*0.0625=0.125
 ! = dcz=2*4/64.  Pure H, Te fixed 1e4.
 par%no_photons=8.0e6
 par%no_print=8.0e6
 par%iseed=1234
 par%grid_type='car'
 par%car_walk='dda'
 par%nx=1
 par%ny=1
 par%nz=64
 par%xmax=0.0625
 par%ymax=0.0625
 par%zmax=4.0
 par%nH_const=100.0
 par%rmax=100.0
 par%dust_model='none'
 par%distance_unit='pc'
 par%xy_periodic=.true.
 par%use_ion_band=.true.
 par%nnu_ion=32
 par%eion_min=13.598
 par%eion_max=100.0
 par%tstar=4.0e4
 par%He_abund=0.0
 par%xHI_init=1.0
 par%ion_add_dust=.false.
 par%gas_niter=60
 par%gas_tol=2.0e-3
 par%conv_crit='vol'
 par%te_fixed=1.0e4
 par%case_ab='B'
 par%source_geometry='slab'
 par%slab_faces='top'
 par%slab_top_mode='beam'
 par%slab_top_theta=0.0
 par%slab_top_source=1.0
 par%file_format='hdf5'
 par%out_file='ge_slab.h5'
/
