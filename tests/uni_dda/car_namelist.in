&parameters
 ! MoCHII car-grid namelist test: the SAME Stromgren sphere as uni_dda.in
 ! (uniform nH=100, R=4 pc sphere, Q_H=1e49, case B, Te=1e4 K) but built
 ! entirely from the namelist -- no amr_file.  par%nH_const sets the uniform
 ! density; par%rmax cuts the sphere on the leaf centers.  Must reproduce the
 ! file-built 'car' run (uni_dda.in) leaf-by-leaf.

 par%no_photons    = 4.0e7
 par%no_print      = 4.0e7
 par%iseed         = 1234

 par%grid_type     = 'car'
 par%car_walk      = 'shared'
 par%nx            = 64
 par%ny            = 64
 par%nz            = 64
 par%xmax          = 4.0
 par%ymax          = 4.0
 par%zmax          = 4.0
 par%nH_const      = 100.0
 par%rmax          = 4.0
 par%dust_model    = 'none'
 par%distance_unit = 'pc'

 par%use_ion_band  = .true.
 par%nnu_ion       = 32
 par%eion_min      = 13.598
 par%eion_max      = 100.0
 par%tstar         = 4.0e4
 par%luminosity    = 3.177837e38

 par%xHI_init      = 1.0
 par%xHeI_init     = 1.0
 par%xHeII_init    = 0.0
 par%He_abund      = 0.1
 par%ion_add_dust  = .false.

 par%gas_niter     = 100
 par%gas_tol       = 2.0e-3
 par%te_fixed      = 1.0e4
 par%ion_relax     = 1.0
 par%case_ab       = 'B'

 par%source_geometry = 'point'
 par%file_format     = 'hdf5'
 par%out_file        = 'car_namelist.h5'
/
