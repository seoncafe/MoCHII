&parameters
 ! MoCHII G1 gate: Stromgren sphere.  Uniform nH = 100 cm^-3 sphere
 ! (R = 4 pc), central blackbody source (4e4 K) with band photon rate
 ! Q_H = 1e49 s^-1, case B, fixed Te = 1e4 K.
 ! Analytic (sharp-edge): R_S = 3.153 pc; exact profile from the 1D
 ! radial-marching reference in check_g1_stromgren.py.

 par%no_photons    = 2.0e6
 par%no_print      = 4.0e7
 par%iseed         = 1234

 par%grid_type     = 'amr'
 par%amr_file      = 'amr_sphere_L5_nH100.fits'
 par%dust_model    = 'global_dgr'
 par%distance_unit = 'pc'

 !--- ionizing band: L set so that Q_H = 1e49 s^-1 (mean E = 19.834 eV)
 par%use_ion_band  = .true.
 par%nnu_ion       = 32
 par%eion_min      = 6.0
 par%eion_max      = 100.0
 par%tstar         = 4.0e4
 par%luminosity    = 6.663648e38

 !--- initial state: fully neutral
 par%xHI_init      = 1.0e-3
 par%xHeI_init     = 0.0
 par%xHeII_init    = 1.0
 par%He_abund      = 0.1
 par%ion_add_dust  = .false.

 !--- G1 iteration (case B on-the-spot, fixed Te)
 par%gas_niter     = 6
 par%gas_tol       = 2.0e-3
 par%te_fixed      = 1.0e4
 par%ion_relax     = 1.0
 par%case_ab       = 'B'

 par%source_geometry = 'point'
 par%file_format     = 'hdf5'
 par%out_file        = 'pahlive_smoke.h5'

 !--- dust in the ionizing band (MW D03 EUV extinction)
 par%ion_add_dust  = .true.
 par%ion_dust_scatter = .true.
 par%ion_dust_kext = '../../data/kext_albedo_WD_MW_3.1_60_D03.all_2009'
 par%cext_dust     = 4.868e-22
 par%DGR           = 1.0

 !--- SEDust stochastic dust SED (output time)
 par%dust_sed       = .true.
 par%dust_model_sed = 'astrodust'
 !--- dust band emissivities for IR maps
 par%dust_emis_bands(1) = 8.0
 par%dust_emis_bands(2) = 24.0
 par%dust_emis_bands(3) = 70.0
 par%dust_emis_bands(4) = 160.0
 par%sed_pah_live = .true.
/
