&parameters
 ! MoCHII G4 demo: photoionization post-processing of an Illustris-TNG
 ! gas cutout (MoCafe converter output; 60 kpc box, uniform level 5,
 ! nH and xHI columns from the simulation).  A starburst-scale source
 ! (Q_H = 1e53 s^-1, 40 kK) sits at the density peak; thermal balance +
 ! metals on; the I-front re-refinement (level 5 -> 7) runs at
 ! iteration 15.

 par%no_photons    = 2.0e7
 par%no_print      = 2.0e7
 par%iseed         = 1234

 par%grid_type     = 'amr'
 par%amr_file      = 'tng_uniform.fits'
 par%dust_model    = 'none'
 par%distance_unit = 'kpc'

 !--- ionizing band: Q_H = 1e53 (mean E = 19.834 eV at 40 kK)
 par%use_ion_band  = .true.
 par%nnu_ion       = 32
 par%eion_min      = 13.598
 par%eion_max      = 100.0
 par%tstar         = 4.0e4
 par%luminosity    = 3.178e42

 !--- initial state from the snapshot xHI column (He tied to H)
 par%xHI_init      = 1.0
 par%xHeI_init     = 0.1
 par%xHeII_init    = 0.9
 par%He_abund      = 0.1
 par%ion_add_dust  = .false.

 !--- iteration: thermal balance + metals, case B
 par%gas_niter     = 40
 par%gas_tol       = 5.0e-3
 par%ion_relax     = 1.0
 par%case_ab       = 'B'
 par%solve_te      = .true.
 par%te_min        = 3.0e3
 par%te_max        = 3.0e4
 par%gas_tol_te    = 5.0e-3
 par%atomic_dir    = '../../data/atomic'
 par%use_metals    = .true.

 !--- G4: I-front re-refinement demo
 par%refine_front  = .true.
 par%refine_iter   = 15
 par%refine_lbase  = 5
 par%refine_lmax   = 7
 par%refine_eps    = 1.0e-2
 par%refine_dx     = 0.2

 !--- source at the density peak (code coordinates, recentered box)
 par%source_geometry = 'point'
 par%xs_point      = -4.6875
 par%ys_point      = -15.9375
 par%zs_point      =  4.6875

 par%file_format     = 'hdf5'
 par%out_file        = 'g4_tng.h5'
/
