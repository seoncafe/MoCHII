&parameters
 ! MoCHII external-field validation: isotropic ionizing field entering the box
 ! faces (source_geometry='external_rec').  An optically thin uniform box
 ! (tau_HI << 1) illuminated by an isotropic field of mean intensity
 ! J = ext_intensity must tally interior band-integrated J = ext_intensity.
 ! Normalization under test: entering ionizing power L = pi*J*A_box.

 par%no_photons    = 2.0e7
 par%no_print      = 2.0e7
 par%iseed         = 1234

 par%grid_type     = 'car'
 par%car_walk      = 'dda'
 par%nx            = 32
 par%ny            = 32
 par%nz            = 32
 par%xmax          = 2.0
 par%ymax          = 2.0
 par%zmax          = 2.0
 par%nH_const      = 1.0e-4
 par%dust_model    = 'none'
 par%distance_unit = 'pc'

 par%use_ion_band  = .true.
 par%nnu_ion       = 32
 par%eion_min      = 13.598
 par%eion_max      = 100.0
 par%tstar         = 4.0e4

 par%xHI_init      = 1.0
 par%He_abund      = 0.0
 par%ion_add_dust  = .false.

 par%gas_niter     = 0

 par%source_geometry = 'external_rec'
 par%ext_intensity   = 1.0e-5

 par%file_format   = 'hdf5'
 par%out_file      = 'ext_rec.h5'
/
